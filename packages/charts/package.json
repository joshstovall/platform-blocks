{
  "name": "@platform-blocks/charts",
  "version": "0.8.1",
  "description": "Data visualization chart components for React Native and Web — bar, line, area, pie, scatter, radar, heatmap, and more",
  "type": "module",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js",
      "default": "./lib/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "npm run clean && rollup -c",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.json --emitDeclarationOnly",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf lib || true",
    "prepare": "sh -c 'if [ \"$BUILD_ON_PREPARE\" = \"1\" ]; then npm run build; else echo \"charts: skipping build on prepare (set BUILD_ON_PREPARE=1 to enable)\"; fi'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0",
    "react-native": ">=0.73.0",
    "react-native-reanimated": ">=3.4.0",
    "react-native-svg": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "@testing-library/react-native": "^13.3.0",
    "@types/jest": "^30.0.0",
    "@babel/core": "^7.25.2",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "@react-native/babel-preset": "^0.83.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-reanimated": "4.2.1",
    "react-native-svg": "15.15.3",
    "react-test-renderer": "19.2.0",
    "rollup": "^4.52.3",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.8.1",
    "typescript": "~5.9.2"
  },
  "keywords": [
    "react-native",
    "charts",
    "data-visualization",
    "svg",
    "typescript",
    "react-native-svg",
    "bar-chart",
    "line-chart",
    "pie-chart",
    "area-chart"
  ],
  "author": "Josh Stovall",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshstovall/platform-blocks.git",
    "directory": "packages/charts"
  },
  "bugs": {
    "url": "https://github.com/joshstovall/platform-blocks/issues"
  },
  "homepage": "https://platform-blocks.com"
}
