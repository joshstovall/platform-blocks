{
  "name": "@platform-blocks/docs",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "docs:generate": "node -e \"console.log('docs:generate skipped (legacy unified removed)')\"",
    "demos:generate": "npx --yes tsx ../../scripts/generate-demos.ts",
    "demos:validate": "npx --yes tsx ../../scripts/validate-demos.ts",
    "postinstall": "npm run demos:generate && (npm run demos:validate || true) && npm run generate-code-map",
    "create-demo": "tsx scripts/create-demo.ts",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:demos": "eslint examples/components --ext .tsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "generate-code-map": "npx --yes tsx scripts/generate-static-code-map.ts",
    "generate-sitemap": "npx --yes tsx ../../scripts/generate-sitemap.ts",
    "generate-llms": "npx --yes tsx ../../scripts/generate-llms.ts",
    "generate-seo": "npm run generate-sitemap && npm run generate-llms",
    "build-web": "npm run generate-seo && expo export --platform web && npm run postbuild",
    "postbuild": "npm run inject-seo",
    "inject-seo": "npx tsx scripts/inject-seo-tags.ts",
    "preview-build": "npm run build-web && npx serve dist",
    "test-prerender": "npm run build-web && npm run check-prerender",
    "check-prerender": "npx tsx scripts/check-prerender.ts",
    "serve-dist": "npx serve dist"
  },
  "dependencies": {
    "@babel/preset-flow": "^7.27.1",
    "@babel/runtime": "^7.28.3",
    "@expo/log-box": "^56.0.12",
    "@expo/metro-runtime": "~56.0.13",
    "@platform-blocks/charts": "file:../../packages/charts",
    "@platform-blocks/ui": "file:../../packages/ui",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.8",
    "expo-audio": "~56.0.11",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-document-picker": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.13",
    "expo-navigation-bar": "~56.0.3",
    "expo-router": "~56.2.8",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.17",
    "expo-video-thumbnails": "~56.0.3",
    "glob": "^11.0.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/node": "^24.3.0",
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~56.0.4",
    "nodemon": "^3.1.10",
    "react-refresh": "^0.17.0",
    "serve": "^14.2.4",
    "tsx": "^4.20.5",
    "typescript": "~6.0.3"
  },
  "private": true
}
